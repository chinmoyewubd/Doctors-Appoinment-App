<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".SignupActivity"
    android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Signup"
            android:textSize="24sp"
            android:gravity="center_horizontal"
            android:padding="8dp"
            android:textStyle="bold"
            android:textColor="#000000"/>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_margin="16dp"
            android:background="#007BFF">

            <TableLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_margin="2dp"
                android:padding="16dp"
                android:background="#ffffff">

                <TableRow>
                    <TextView
                        android:text="Name"
                        android:textStyle="bold"
                        android:textSize="16sp"/>
                    <TextView
                        android:text=":"
                        android:textSize="16sp"
                        android:layout_marginLeft="4dp"
                        android:layout_marginRight="4dp"/>
                    <EditText
                        android:layout_weight="1"
                        android:id="@+id/etName"
                        android:inputType="textCapWords"
                        android:maxLength="8"/>
                </TableRow>

                <TableRow
                    android:layout_marginTop="12dp">
                    <TextView
                        android:text="Email"
                        android:textStyle="bold"
                        android:textSize="16sp"/>
                    <TextView
                        android:text=":"
                        android:textSize="16sp"
                        android:layout_marginLeft="4dp"
                        android:layout_marginRight="4dp"/>
                    <EditText
                        android:layout_weight="1"
                        android:id="@+id/etEmail"
                        android:hint="Enter Email"
                        android:inputType="textEmailAddress"
                        android:maxLength="128"/>
                </TableRow>

                <TableRow
                    android:layout_marginTop="12dp">
                    <TextView
                        android:text="Phone"
                        android:textStyle="bold"
                        android:textSize="16sp"/>
                    <TextView
                        android:text=":"
                        android:textSize="16sp"
                        android:layout_marginLeft="4dp"
                        android:layout_marginRight="4dp"/>
                    <EditText
                        android:layout_weight="1"
                        android:id="@+id/etPhone"
                        android:inputType="phone"
                        android:hint="Enter Phone"
                        android:maxLength="13"/>
                </TableRow>

                <TableRow
                    android:layout_marginTop="12dp">
                    <TextView
                        android:text="Password"
                        android:textStyle="bold"
                        android:textSize="16sp"/>
                    <TextView
                        android:text=":"
                        android:textSize="16sp"
                        android:layout_marginLeft="4dp"
                        android:layout_marginRight="4dp"/>
                    <EditText
                        android:layout_weight="1"
                        android:id="@+id/etPassword"
                        android:inputType="numberPassword"
                        android:maxLength="4"/>
                </TableRow>

                <TableRow
                    android:layout_marginTop="12dp">
                    <TextView
                        android:text="Confirm Password"
                        android:textStyle="bold"
                        android:textSize="16sp"/>
                    <TextView
                        android:text=":"
                        android:textSize="16sp"
                        android:layout_marginLeft="4dp"
                        android:layout_marginRight="4dp"/>
                    <EditText
                        android:layout_weight="1"
                        android:hint="cPass"
                        android:id="@+id/etConfirmPassword"
                        android:inputType="numberPassword"/>
                </TableRow>

                <CheckBox
                    android:id="@+id/cbRememberUser"
                    android:text="Remember User"
                    android:textSize="16sp"
                    android:layout_marginTop="16dp"/>
                <CheckBox
                    android:id="@+id/cbRememberLogin"
                    android:text="Remember Login"
                    android:textSize="16sp"/>
                <Button
                    android:id="@+id/btnLogin"
                    android:text="Already have an account?"
                    android:layout_marginTop="32dp"/>
            </TableLayout>
        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <Button
                android:id="@+id/btnSignInstructor"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Signup as\nInstructor"
                android:backgroundTint="#6C757D"/>
            <Button
                android:id="@+id/btnSignStudent"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Signup as\nStudent"
                android:backgroundTint="#007BFF "/>
        </LinearLayout>
    </LinearLayout>
