<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    tools:context=".DoctorListActivity">
    <LinearLayout

        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:layout_marginTop="25dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:padding="8dp"
            android:text="ALL DOCTORS LIST"
            android:textColor="#000000"
            android:textSize="24sp"
            android:textStyle="bold"
            android:background="#95F297"/>

        <Button
            android:id="@+id/btnSpecialityWise"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:text="SpecialityWise"
            android:backgroundTint="#50E256"
            android:padding="2dp"
            android:layout_margin="10dp"/>


    </LinearLayout>


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_margin="16dp"
        android:background="#ff8844"
        android:orientation="vertical"
        android:padding="2dp">


        <LinearLayout
            xmlns:android="http://schemas.android.com/apk/res/android"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:orientation="horizontal"
            android:background="#888888"
            android:layout_marginBottom="2dp">
            <TextView
                android:id="@+id/tvSN"
                android:layout_width="50dp"
                android:layout_height="match_parent"
                android:text="S/N"
                android:gravity="center"
                android:paddingStart="4dp"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:paddingEnd="4dp"
                android:background="#95F297"
                android:layout_marginRight="1dp"/>
            <TextView
                android:id="@+id/tvID"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:text="Doctor's ID"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:gravity="center"
                android:layout_weight="0.6"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:background="#95F297"
                android:layout_marginRight="1dp"/>
            <TextView
                android:id="@+id/tvName"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="Doctor Name"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:gravity="center"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:background="#95F297"
                android:layout_marginRight="1dp"/>
            <TextView
                android:id="@+id/tvSpeciality"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="Doctor Speciality"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:gravity="center"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:background="#95F297"
                android:layout_marginRight="1dp"/>

        </LinearLayout>

        <ListView
            android:id="@+id/lvDoctor"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#ffff"
            android:dividerHeight="3dp"
            android:listSelector="#FBF9F6"
            android:textColor="@color/black" />

    </LinearLayout>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <Button
            android:id="@+id/btnLoad"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_margin="5dp"
            android:layout_height="wrap_content"
            android:text="Lod All \nDoctor data"
            android:textStyle="bold"
            android:backgroundTint="#50E256"
            android:textColor="@color/black"/>
        <Button
            android:id="@+id/btnAddDoctor"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_margin="5dp"
            android:layout_height="wrap_content"
            android:text="Add\nDoctor"
            android:backgroundTint="#50E256"
            android:textStyle="bold"
            android:textColor="@color/black"/>
    </LinearLayout>


</LinearLayout>
