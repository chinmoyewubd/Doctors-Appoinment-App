<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".LoginActivity">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="86dp"
        android:background="#7CD382"
        android:gravity="center"
        android:padding="8dp"
        android:text="Login"
        android:textColor="#000000"
        android:textSize="35sp"
        android:textStyle="bold"/>


        <TableLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_margin="2dp"
            android:padding="16dp"
            android:background="#E9EBE5">

            <TableRow
                android:layout_marginTop="12dp">
                <TextView
                    android:text="Email"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:textColor="@color/black"/>
                <TextView
                    android:text=":"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginLeft="4dp"
                    android:layout_marginRight="4dp"
                    android:textColor="@color/black"/>
                <EditText
                    android:id="@+id/etEmail"
                    android:layout_width="0dp"
                    android:layout_weight="2"
                    android:inputType="text"
                    android:maxLength="128"
                    android:textColor="@color/black"
                    android:paddingBottom="10dp"
                    android:layout_marginBottom="10dp"
                    android:background="@color/white"/>
            </TableRow>

            <TableRow
                android:layout_marginTop="12dp">
                <TextView
                    android:text="Password"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:textColor="@color/black"/>
                <TextView
                    android:text=":"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginLeft="4dp"
                    android:layout_marginRight="4dp"
                    android:textColor="@color/black"/>
                <EditText
                    android:layout_weight="1"
                    android:id="@+id/etPassword"
                    android:textColor="@color/black"
                    android:paddingBottom="10dp"
                    android:layout_marginBottom="10dp"
                    android:background="@color/white"/>
            </TableRow>

            <CheckBox
                android:id="@+id/cbRememberUser"
                android:text="Remember User"
                android:textSize="18sp"
                android:layout_marginTop="16dp"
                android:textColor="@color/black"/>
            <CheckBox
                android:id="@+id/cbRememberLogin"
                android:text="Remember Login"
                android:textSize="18sp"
                android:textColor="@color/black"/>
            <Button
                android:id="@+id/btnSignup"
                android:text="Don't have an account?"
                android:layout_marginTop="100dp"
                android:backgroundTint="#ED8A81"
                android:textStyle="bold"
                android:textColor="@color/black"/>
        </TableLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnLoginInstructor"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_margin="10dp"
            android:textStyle="bold"
            android:backgroundTint="#53E759"
            android:text="Login as\nAdmin" />

        <Button
            android:id="@+id/btnLoginStudent"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_margin="10dp"
            android:textStyle="bold"
            android:layout_height="wrap_content"
            android:text="Login as\nPatient"
            android:backgroundTint="#53E759"/>
    </LinearLayout>

</LinearLayout>